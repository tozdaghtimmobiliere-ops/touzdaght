generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model City {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  heroImage String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
}

model Project {
  id          Int            @id @default(autoincrement())
  cityId      Int
  name        String
  slug        String         @unique
  type        String
  status      String         @default("active")
  description String?
  address     String?
  totalArea   Float?
  startDate   DateTime?
  endDate     DateTime?
  heroImage   String?
  mainImage   String?
  whatsapp    String         @default("212702060323")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  buildings   Building[]
  parcels     Parcel[]
  city        City           @relation(fields: [cityId], references: [id])
  images      ProjectImage[]
}

model ProjectImage {
  id        Int      @id @default(autoincrement())
  projectId Int
  url       String
  category  String
  label     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Building {
  id                 Int         @id @default(autoincrement())
  projectId          Int
  name               String
  floorsCount        Int
  apartmentsPerFloor Int
  totalSurface       Float?
  floorLabels        String?
  tableauSection     String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  apartments         Apartment[]
  project            Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Apartment {
  id         Int      @id @default(autoincrement())
  buildingId Int
  floor      Int
  unitNumber Int
  rooms      Int?     @default(2)
  salons     Int?     @default(1)
  kitchens   Int?     @default(1)
  bathrooms  Int?     @default(1)
  surface    Float?
  price      Float?
  status     String   @default("available")
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([buildingId, floor, unitNumber])
}

model Parcel {
  id           Int      @id @default(autoincrement())
  projectId    Int
  parcelNumber Int
  parcelCode   String
  usageType    String
  zoneType     String
  surface      Float?
  price        Float?
  status       String   @default("available")
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, parcelNumber, parcelCode])
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  role         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ReservationLog {
  id          Int      @id @default(autoincrement())
  adminId     Int
  unitType    String
  unitId      Int
  oldStatus   String
  newStatus   String
  messageSent String?
  createdAt   DateTime @default(now())
}
