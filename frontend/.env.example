# --- DATABASE (Supabase) ---
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres"

# --- AUTHENTICATION (NextAuth v5) ---
NEXTAUTH_URL="https://tozdaght.ma"
NEXTAUTH_SECRET="[GENERATE_A_LONG_SECRET]"

# --- CLERK (Alternative Auth) ---
